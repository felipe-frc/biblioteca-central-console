@model IEnumerable<Biblioteca.Domain.Entities.Usuario>
@using System.Linq

@{
    ViewData["Title"] = "Usuários";

    var usuarios = Model?.ToList() ?? new List<Biblioteca.Domain.Entities.Usuario>();
    var totalUsuarios = ViewBag.TotalUsuarios is int tu ? tu : usuarios.Count;
    var comEmail = ViewBag.ComEmail is int ce ? ce : usuarios.Count(u => !string.IsNullOrWhiteSpace(u.Email));
    var usuariosInadimplentes = ViewBag.UsuariosInadimplentes is int ui ? ui : 0;

    var currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    var hasPreviousPage = ViewBag.HasPreviousPage is bool hp && hp;
    var hasNextPage = ViewBag.HasNextPage is bool hn && hn;
}

<section class="crud-page crud-page-usuarios">
    <div class="container">
        @if (TempData["Erro"] is not null)
        {
            <div class="crud-alert crud-alert-danger">@TempData["Erro"]</div>
        }

        @if (TempData["Sucesso"] is not null)
        {
            <div class="crud-alert crud-alert-success">@TempData["Sucesso"]</div>
        }

        <div class="crud-header">
            <h1 class="crud-title">Usuários</h1>
            <span class="crud-line"></span>
            <a class="crud-primary-btn" asp-controller="Usuarios" asp-action="Create">+ Novo Usuário</a>
        </div>

        @if (!usuarios.Any())
        {
            <div class="crud-empty-state">
                <h3>Nenhum usuário cadastrado.</h3>
                <p>Cadastre o primeiro usuário para começar a gerenciar a biblioteca.</p>
            </div>
        }
        else
        {
            <div class="crud-table-card">
                <div class="crud-table-wrap">
                    <table class="crud-table">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in usuarios)
                            {
                                <tr>
                                    <td class="crud-id" data-label="Id">@u.Id</td>
                                    <td class="crud-strong" data-label="Nome">@u.Nome</td>
                                    <td data-label="Email">@u.Email</td>
                                    <td class="crud-actions-cell" data-label="Ações">
                                        <div class="crud-actions">
                                            <a class="crud-action-btn crud-action-btn-edit"
                                               asp-controller="Usuarios"
                                               asp-action="Edit"
                                               asp-route-id="@u.Id">
                                                <span class="crud-action-icon" aria-hidden="true">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M12 20h9" />
                                                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                                                    </svg>
                                                </span>
                                                Editar
                                            </a>

                                            <a class="crud-action-btn crud-action-btn-delete"
                                               asp-controller="Usuarios"
                                               asp-action="Delete"
                                               asp-route-id="@u.Id">
                                                <span class="crud-action-icon" aria-hidden="true">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M3 6h18" />
                                                        <path d="M8 6V4h8v2" />
                                                        <path d="M19 6l-1 14H6L5 6" />
                                                        <path d="M10 11v6" />
                                                        <path d="M14 11v6" />
                                                    </svg>
                                                </span>
                                                Excluir
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (totalPages > 0)
            {
                <nav class="crud-pagination" aria-label="Paginação">
                    @if (hasPreviousPage)
                    {
                        <a class="crud-pagination-link" asp-action="Index" asp-route-page="@(currentPage - 1)">Anterior</a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Anterior</span>
                    }

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == currentPage)
                        {
                            <span class="crud-pagination-link is-active">@i</span>
                        }
                        else
                        {
                            <a class="crud-pagination-link" asp-action="Index" asp-route-page="@i">@i</a>
                        }
                    }

                    @if (hasNextPage)
                    {
                        <a class="crud-pagination-link" asp-action="Index" asp-route-page="@(currentPage + 1)">Próxima</a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Próxima</span>
                    }
                </nav>
            }

            <div class="row g-4 crud-stats-row">
                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Total de Usuários</span>
                        <strong class="crud-stat-value">@totalUsuarios</strong>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-blue">
                        <span class="crud-stat-label">Com Email</span>
                        <strong class="crud-stat-value">@comEmail</strong>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Usuários Inadimplentes</span>
                        <strong class="crud-stat-value">@usuariosInadimplentes</strong>
                    </div>
                </div>
            </div>
        }
    </div>
</section>