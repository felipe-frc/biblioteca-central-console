@model Biblioteca.Domain.Entities.Livro

@{
    ViewData["Title"] = "Editar Livro";
}

<h2>Editar Livro</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <input type="hidden" name="id" value="@Model.Id" />

    <div class="mb-3">
        <label class="form-label">Título</label>
        <input class="form-control" name="titulo" value="@Model.Titulo" />
    </div>

    <div class="mb-3">
        <label class="form-label">Autor</label>
        <input class="form-control" name="autor" value="@Model.Autor" />
    </div>

    <div class="mb-3">
        <label class="form-label">Ano de publicação</label>
        <input class="form-control" name="anoPublicacao" type="number" value="@Model.AnoPublicacao" />
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a class="btn btn-secondary" asp-controller="Livros" asp-action="Index">Cancelar</a>
</form>