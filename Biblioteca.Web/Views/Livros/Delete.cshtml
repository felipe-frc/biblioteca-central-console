@model Biblioteca.Domain.Entities.Livro

@{
    bool temEmprestimoRelacionado = ViewBag.TemEmprestimoRelacionado ?? false;
    ViewData["Title"] = "Excluir Livro";
    Layout = "~/Views/Shared/_LayoutInner.cshtml";
}

<section class="crud-page crud-form-page">
    <div class="container">
        <div class="crud-header crud-header-form">
            <div>
                <h1 class="crud-title">Excluir Livro</h1>
                <span class="crud-line"></span>
            </div>
        </div>

        <div class="crud-form-card">
            <div class="crud-alert crud-alert-warning">
                Tem certeza que deseja excluir o livro abaixo?
            </div>

            <div class="crud-delete-list">
                <div class="crud-delete-item"><strong>Id:</strong> @Model.Id</div>
                <div class="crud-delete-item"><strong>Título:</strong> @Model.Titulo</div>
                <div class="crud-delete-item"><strong>Autor:</strong> @Model.Autor</div>
                <div class="crud-delete-item"><strong>Ano de Publicação:</strong> @Model.AnoPublicacao</div>
                <div class="crud-delete-item"><strong>Disponível:</strong> @(Model.Disponivel ? "Sim" : "Não")</div>
            </div>

            @if (temEmprestimoRelacionado)
            {
                <div class="crud-alert crud-alert-danger">
                    Não é possível excluir este livro porque ele possui empréstimos registrados no histórico.
                </div>

                <div class="crud-form-actions">
                    <a asp-controller="Livros" asp-action="Index" class="crud-secondary-btn">Voltar</a>
                </div>
            }
            else
            {
                <form asp-action="DeleteConfirmed" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="crud-form-actions">
                        <button type="submit" class="crud-action-btn crud-action-btn-delete">Confirmar Exclusão</button>
                        <a asp-controller="Livros" asp-action="Index" class="crud-secondary-btn">Cancelar</a>
                    </div>
                </form>
            }
        </div>
    </div>
</section>