@model Biblioteca.Domain.Entities.Emprestimo

@{
    ViewData["Title"] = "Devolver Empréstimo";
}

<h2>Devolver Empréstimo</h2>

<div class="alert alert-warning">
    Tem certeza que deseja devolver este empréstimo?
</div>

<ul class="list-group mb-3">
    <li class="list-group-item"><strong>Id:</strong> @Model.Id</li>
    <li class="list-group-item"><strong>Livro:</strong> @Model.Livro.Titulo</li>
    <li class="list-group-item"><strong>Usuário:</strong> @Model.Usuario.Nome</li>
    <li class="list-group-item"><strong>Data do empréstimo:</strong> @Model.DataEmprestimo.ToString("dd/MM/yyyy")</li>
    <li class="list-group-item"><strong>Prevista devolução:</strong> @Model.DataPrevistaDevolucao.ToString("dd/MM/yyyy")</li>
</ul>

<form asp-action="DevolverConfirmed" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-success">Confirmar Devolução</button>
    <a class="btn btn-secondary" asp-controller="Emprestimos" asp-action="Index">Cancelar</a>
</form>