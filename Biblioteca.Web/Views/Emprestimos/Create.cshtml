@model Biblioteca.Web.ViewModels.EmprestimoFormViewModel

@{
    ViewData["Title"] = "Novo Empréstimo";
    Layout = "~/Views/Shared/_LayoutInner.cshtml";
}

<section class="crud-page crud-form-page">
    <div class="container">
        <div class="crud-header crud-header-form">
            <div>
                <h1 class="crud-title">Novo Empréstimo</h1>
                <span class="crud-line"></span>
            </div>
        </div>

        <div class="crud-form-card">
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="crud-alert crud-alert-danger crud-validation-summary"></div>

                <p class="mb-4 fw-semibold text-danger">
                    * Campo obrigatório
                </p>

                <div class="crud-form-grid">
                    <div class="crud-form-group">
                        <label asp-for="UsuarioId" class="crud-form-label">
                            Usuário <span class="text-danger">*</span>
                        </label>
                        <select asp-for="UsuarioId" asp-items="Model.Usuarios" class="crud-form-control crud-form-select">
                            <option value="">Selecione...</option>
                        </select>
                        <span asp-validation-for="UsuarioId" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group">
                        <label asp-for="LivroId" class="crud-form-label">
                            Livro <span class="text-danger">*</span>
                        </label>
                        <select asp-for="LivroId" asp-items="Model.Livros" class="crud-form-control crud-form-select">
                            <option value="">Selecione...</option>
                        </select>
                        <span asp-validation-for="LivroId" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group crud-form-group-small">
                        <label asp-for="DataPrevistaDevolucao" class="crud-form-label">
                            Data prevista para devolução <span class="text-danger">*</span>
                        </label>
                        <input asp-for="DataPrevistaDevolucao" class="crud-form-control" type="date" />
                        <span asp-validation-for="DataPrevistaDevolucao" class="crud-field-validation"></span>
                    </div>
                </div>

                <div class="crud-form-actions">
                    <button type="submit" class="crud-primary-btn">Salvar Empréstimo</button>
                    <a asp-action="Index" class="crud-secondary-btn">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}