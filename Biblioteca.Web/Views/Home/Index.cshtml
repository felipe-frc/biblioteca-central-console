@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}

<section class="hero-section">
    <div class="container">
        <div class="hero-content">
            <span class="section-line"></span>
            <h1 class="hero-title">Bem-vindo à Biblioteca Áurea</h1>
            <p class="hero-text">
                Descubra um espaço elegante para gerenciar sua coleção de livros, usuários e empréstimos com sofisticação e eficiência.
                Uma solução completa para bibliotecas modernas.
            </p>

            <div class="hero-actions">
                <a asp-controller="Livros" asp-action="Index" class="btn-hero-primary">Explorar Livros</a>
                <a href="#colecao" class="btn-hero-secondary">Saiba Mais</a>
            </div>
        </div>
    </div>
</section>

<section id="funcionalidades" class="features-section">
    <div class="container">
        <div class="section-heading-center">
            <h2 class="section-title-center">Recursos do Sistema</h2>
            <span class="section-line-center"></span>
        </div>

        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <article class="feature-card">
                    <div class="feature-icon feature-icon-blue-gold">📚</div>
                    <h3 class="feature-card-title">Gestão de Livros</h3>
                    <p class="feature-card-text">
                        Cadastre, edite e acompanhe a disponibilidade de cada obra com organização e praticidade.
                    </p>
                </article>
            </div>

            <div class="col-lg-4 col-md-6">
                <article class="feature-card">
                    <div class="feature-icon feature-icon-blue-gold">👥</div>
                    <h3 class="feature-card-title">Controle de Usuários</h3>
                    <p class="feature-card-text">
                        Gerencie usuários com segurança, mantendo dados essenciais para o funcionamento da biblioteca.
                    </p>
                </article>
            </div>

            <div class="col-lg-4 col-md-6">
                <article class="feature-card">
                    <div class="feature-icon feature-icon-gold-red">🔄</div>
                    <h3 class="feature-card-title">Empréstimos e Devoluções</h3>
                    <p class="feature-card-text">
                        Registre movimentações com clareza e acompanhe o histórico completo de empréstimos.
                    </p>
                </article>
            </div>
        </div>
    </div>
</section>

<section id="colecao" class="collection-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="collection-image-wrap">
                    <img src="~/images/colecao-livros.png"
                         asp-append-version="true"
                         alt="Coleção de livros da Biblioteca Áurea"
                         class="collection-image" />
                </div>
            </div>

            <div class="col-lg-6">
                <h2 class="collection-title">Nossa Coleção Especial</h2>
                <p class="collection-text">
                    A Biblioteca Áurea oferece uma coleção cuidadosamente selecionada de livros em diversas categorias.
                    Cada obra é catalogada com precisão para facilitar a busca e o gerenciamento.
                </p>

                <ul class="collection-list">
                    <li>Catálogo completo e organizado</li>
                    <li>Informações detalhadas de cada livro</li>
                    <li>Controle de disponibilidade em tempo real</li>
                    <li>Histórico de empréstimos e devoluções</li>
                    <li>Busca avançada por título, autor ou categoria</li>
                </ul>

                <a asp-controller="Livros" asp-action="Index" class="btn-hero-primary mt-4">
                    Explorar Coleção Completa
                </a>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <div class="cta-content">
            <h2 class="cta-title">Pronto para começar?</h2>
            <p class="cta-text">
                Acesse agora o sistema da Biblioteca Áurea e organize sua coleção com elegância e eficiência.
            </p>
            <a asp-controller="Livros" asp-action="Index" class="btn-cta">Acessar Sistema</a>
        </div>
    </div>
</section>