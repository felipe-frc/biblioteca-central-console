<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <!-- Meta Tags Essenciais -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <meta name="description" content="Biblioteca Áurea - Sistema de Gerenciamento" />
    <meta name="theme-color" content="#183d60" />

    <!-- Título Dinâmico -->
    <title>@ViewData["Title"] - Biblioteca Áurea</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/images/logo-biblioteca.png" />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Preconnect para Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body class="inner-body">
    <!-- ============================================
         HEADER / NAVBAR INTERNO
         ============================================ -->
    <header>
        <nav class="navbar navbar-expand-lg inner-navbar fixed-top">
            <div class="container-fluid inner-navbar-container">
                <a class="navbar-brand inner-brand"
                   href="@Url.Action("Index", "Home")"
                   aria-label="Biblioteca Áurea - Voltar para Home">
                    <img src="~/images/logo-biblioteca-completa.png"
                         alt="Logo Biblioteca Áurea"
                         class="inner-logo"
                         loading="lazy" />
                </a>

                <button class="navbar-toggler inner-navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#innerMenu"
                        aria-controls="innerMenu"
                        aria-expanded="false"
                        aria-label="Abrir menu de navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="innerMenu">
                    <ul class="navbar-nav ms-auto inner-nav-list">
                        <li class="nav-item">
                            <a class="nav-link inner-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                               href="@Url.Action("Index", "Home")"
                               aria-current="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "page" : "false")">
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link inner-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Livros" ? "active" : "")"
                               href="@Url.Action("Index", "Livros")"
                               aria-current="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Livros" ? "page" : "false")">
                                Livros
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link inner-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")"
                               href="@Url.Action("Index", "Usuarios")"
                               aria-current="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "page" : "false")">
                                Usuários
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link inner-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Emprestimos" ? "active" : "")"
                               href="@Url.Action("Index", "Emprestimos")"
                               aria-current="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Emprestimos" ? "page" : "false")">
                                Empréstimos
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ============================================
         MAIN CONTENT
         ============================================ -->
    <main class="inner-main">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- ============================================
         FOOTER INTERNO
         ============================================ -->
    <footer class="inner-footer">
        <div class="container-fluid text-center">
            <p class="mb-0">&copy; 2026 Biblioteca Áurea. Todos os direitos reservados.</p>
        </div>
    </footer>

    <!-- ============================================
         SCRIPTS
         ============================================ -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>